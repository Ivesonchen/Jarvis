# Use the public npm registry only — no private feeds.
registry=https://registry.npmjs.org/
auto-install-peers=true
strict-peer-dependencies=false

# Hoist the Copilot CLI's platform-specific binaries to the root
# node_modules so `require.resolve("@github/copilot-<plat>-<arch>")` works
# from our main process. These are optionalDependencies of `@github/copilot`
# (a transitive of `@github/copilot-sdk`) and pnpm's strict isolation
# would otherwise hide them from us.
public-hoist-pattern[]=@github/copilot-*
